# ─── Moodle ──────────────────────────────────────────────
# Bilkent her donem ayri URL kullanir!
MOODLE_URL=https://moodle.bilkent.edu.tr/2025-2026-spring

# Username/Password (token otomatik alinir ve kaydedilir)
MOODLE_USERNAME=
MOODLE_PASSWORD=

# Veya direkt token:
# MOODLE_TOKEN=

# ─── LLM API Keys ───────────────────────────────────────
GEMINI_API_KEY=                    # Google AI Studio (aistudio.google.com/apikey)
OPENAI_API_KEY=                    # OpenAI (intent + extraction icin)
# GLM_API_KEY=                     # Z.ai (opsiyonel fallback)
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ─── Task → Model Routing ───────────────────────────────
# GPT-5 mini: $0.25/$2.0 — en iyi fiyat/performans (onerilen)
# GPT-5 nano: $0.10/$0.40 — basit extraction/classification
# Gemini 2.5 Flash: ucretsiz tier (5 RPM limiti!)
# GPT-4.1-mini: $0.80/$3.20 — eski, daha pahali
MODEL_CHAT=gpt-5-mini              # Ana sohbet + tool calling
MODEL_STUDY=gpt-5-mini             # Study mode (strict grounding)
MODEL_EXTRACTION=gpt-5-nano        # Hafiza cikarma (ucuz, hizli)
MODEL_TOPIC_DETECT=gpt-5-nano      # Konu tespiti (ucuz, hizli)
MODEL_SUMMARY=gpt-5-mini           # Haftalik ozet
MODEL_QUESTIONS=gemini-2.5-flash   # Pratik sorular
MODEL_OVERVIEW=gemini-2.5-flash    # Kurs genel bakis

# ─── Paths ───────────────────────────────────────────────
DATA_DIR=./data
DOWNLOADS_DIR=./data/downloads
CHROMA_DIR=./data/chromadb

# ─── Embedding ───────────────────────────────────────────
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ─── Performance ─────────────────────────────────────────
HF_HUB_OFFLINE=0                   # 0 = ilk calistirmada HF'den indir, sonra 1 yap

# ─── Telegram Bot ────────────────────────────────────────
# @BotFather'dan al: Telegram → @BotFather → /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=                 # Senin Telegram chat ID
# TELEGRAM_ADMIN_IDS=              # Ek admin ID'leri (virgul ayirmali)

# ─── RAG Parametreleri ───────────────────────────────────
# RAG_SIMILARITY_THRESHOLD=0.65
# RAG_MIN_CHUNKS=2
# RAG_TOP_K=5

# ─── Rate Limiting ──────────────────────────────────────
# RATE_LIMIT_MAX=30                # Pencere basina max istek
# RATE_LIMIT_WINDOW=60             # Rate limit penceresi (saniye)

# ─── Konusma Hafizasi ───────────────────────────────────
# MEMORY_MAX_MESSAGES=5
# MEMORY_TTL_MINUTES=30

# ─── Health Check ────────────────────────────────────────
# HEALTHCHECK_ENABLED=true
# HEALTHCHECK_HOST=0.0.0.0
# HEALTHCHECK_PORT=9090

# ─── Log ─────────────────────────────────────────────────
# LOG_LEVEL=INFO

# ─── STARS (Bilkent Ogrenci Bilgi Sistemi) ───────────────
STARS_USERNAME=
STARS_PASSWORD=

# ─── Webmail IMAP (Bilkent) ─────────────────────────────
WEBMAIL_EMAIL=
WEBMAIL_PASSWORD=
